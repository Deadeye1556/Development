# Server-only secrets for the Forkd edge functions.
# These are NOT EXPO_PUBLIC and must never appear in the client bundle.
#
# Local dev:   put real values in supabase/functions/.env (gitignored) and run
#              `supabase functions serve --env-file supabase/functions/.env`
# Deployed:    `supabase secrets set OPENAI_API_KEY=... USDA_API_KEY=...`

OPENAI_API_KEY=
# Optional. Falls back to USDA "DEMO_KEY" (rate-limited) if unset.
USDA_API_KEY=
